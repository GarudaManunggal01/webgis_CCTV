generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
  role     String @default("ADMIN")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CCTV {
  id         Int      @id @default(autoincrement())
  slug       String   @unique
  name       String
  latitude   Float
  longitude  Float
  streamUrl  String
  status     String   @default("online")
  thumbnail  String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
